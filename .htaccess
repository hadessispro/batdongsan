Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteCond %{HTTP:CF-Visitor} !\"scheme\":\"https\" [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  RewriteRule ^data/backups/ - [F,L,NC]
  RewriteRule ^api/config\.local\.php$ - [F,L,NC]

  RewriteCond %{THE_REQUEST} \s/+admin-login\.php[\s?] [NC]
  RewriteRule ^admin-login\.php$ admin [R=302,L]

  RewriteCond %{THE_REQUEST} \s/+admin\.php[\s?] [NC]
  RewriteRule ^admin\.php$ admin/panel [R=302,L]

  RewriteCond %{THE_REQUEST} \s/+admin\.html[\s?] [NC]
  RewriteRule ^admin\.html$ admin/panel [R=302,L]

  RewriteCond %{THE_REQUEST} \s/+asset-version\.php[\s?] [NC]
  RewriteRule ^asset-version\.php$ asset-version.js [R=302,L]

  RewriteRule ^admin/?$ admin-login.php [L,QSA]
  RewriteRule ^admin/panel/?$ admin.php [L,QSA]
  RewriteRule ^asset-version\.js$ asset-version.php [L,QSA]
</IfModule>

# ═══════════════════════════════════════════════════════════
#  BROWSER CACHE — Tối ưu Lighthouse "Use efficient cache lifetimes"
#  
#  Chiến lược:
#  - Ảnh, font, video  → cache 1 NĂM (không đổi thường xuyên)
#  - CSS, JS            → cache 30 NGÀY (có thể update)
#  - HTML               → KHÔNG cache (luôn lấy bản mới nhất)
# ═══════════════════════════════════════════════════════════

# ── Bật mod_expires nếu có ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # ── Ảnh — 1 năm ──
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/gif                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/avif                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # ── Font — 1 năm ──
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType font/ttf                      "access plus 1 year"
  ExpiresByType font/otf                      "access plus 1 year"
  ExpiresByType application/font-woff         "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"
  ExpiresByType application/x-font-ttf        "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

  # ── Video / Audio — 1 năm ──
  ExpiresByType video/mp4                     "access plus 1 year"
  ExpiresByType video/webm                    "access plus 1 year"
  ExpiresByType audio/mpeg                    "access plus 1 year"

  # ── CSS & JS — 30 ngày ──
  ExpiresByType text/css                      "access plus 30 days"
  ExpiresByType application/javascript        "access plus 30 days"
  ExpiresByType text/javascript               "access plus 30 days"

  # ── JSON & Data — không cache để dữ liệu admin cập nhật ngay ──
  ExpiresByType application/json              "access plus 0 seconds"

  # ── PDF — 30 ngày ──
  ExpiresByType application/pdf               "access plus 30 days"

  # ── HTML — không cache (luôn lấy mới) ──
  ExpiresByType text/html                     "access plus 0 seconds"
</IfModule>

# ── Bật mod_headers nếu có — Cache-Control header ─────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests; img-src 'self' data: blob: https://api.mapbox.com https://*.mapbox.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://api.mapbox.com; script-src 'self' 'unsafe-inline' https://api.mapbox.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; connect-src 'self' https://api.mapbox.com https://*.mapbox.com https://events.mapbox.com; worker-src 'self' blob: https://api.mapbox.com https://cdnjs.cloudflare.com; media-src 'self' data: blob:; frame-src 'self' data: blob:;"

  # ── Ảnh, Font, Video → 1 năm + immutable ──
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf|otf|eot|mp4|webm|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # ── CSS & JS → 30 ngày ──
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # ── JSON → không cache để đồng bộ tool/admin với website ──
  <FilesMatch "\.(json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # ── PDF → 30 ngày ──
  <FilesMatch "\.(pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # ── HTML / PHP bootstrap → không cache ──
  <FilesMatch "\.(html|htm|php)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

</IfModule>

# ═══════════════════════════════════════════════════════════
#  GZIP COMPRESSION — Giảm dung lượng tải về
# ═══════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE application/font-woff
  AddOutputFilterByType DEFLATE application/x-font-ttf
</IfModule>
